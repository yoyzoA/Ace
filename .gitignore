# Global .gitignore for Ace workspace

# Node modules
**/node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed

# Environment variables
.env
.env.*

# MacOS files
.DS_Store
.AppleDouble
.LSOverride

# Windows files
Thumbs.db

# Build output
dist/
build/

# Vite cache
**/node_modules/.vite

# Electron output
**/release/
**/win-unpacked/

# IDE directories
.vscode/
.idea/

# Misc files
*.tgz
*.zip
*.cache
*.tmp

# npm & yarn lockfiles (optional to commit)
package-lock.json
yarn.lock

# Yarn v2
.yarn/*
.yarnrc.yml

# coverage
coverage/

# webpack
/.webpack/

# React Native
.expo/

# JetBrains
*.iml
out/

# Personal environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore existing workspace-specific paths which may be tracked inadvertently
# (retain if necessary, or remove after cleaning)
# e.g., build artifacts or zipped backups

# End of .gitignore
